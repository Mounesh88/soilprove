  "om_n_credit": {
    "description": "Organic matter nitrogen credit calculation",
    "formula": "om_credit = (om_pct - 2.5) * 14",
    "base_om_pct": 2.5,
    "credit_per_om_unit": 14,
    "min_credit_lbs_ac": -20,
    "max_credit_lbs_ac": 30,
    "note": "Based on Sawyer et al. 2006. Positive credit reduces N recommendation. Negative credit increases it."
  },
  "price_ratio_calculation": {
    "description": "N cost to corn price ratio drives EONR",
    "formula": "price_ratio = n_cost_per_lb / corn_price_per_bu",
    "typical_range": [0.05, 0.25],
    "note": "Higher ratio means N is expensive relative to corn - reduce application rate"
  },
