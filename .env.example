# Google Gemini AI API Key
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# USDA NASS API Key (Free)
# Get from: https://quickstats.nass.usda.gov/api
USDA_NASS_KEY=your_usda_nass_key_here

# NOAA Climate Data API Key (Free)
# Get from: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_KEY=your_noaa_key_here

# App Settings
APP_NAME=SoilProve
APP_ENV=development
DEBUG=True